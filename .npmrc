auto-install-peers=true
strict-peer-dependencies=false
prefer-workspace-packages=true

# Nuxt + pnpm: many Nuxt modules pull transitive deps (@nuxtjs/mdc -> remark-*,
# parse5, unified, etc.) that Vite expects to be resolvable from each app's
# node_modules. With strict pnpm isolation those dependencies live deep under
# .pnpm and Vite emits "Unresolvable optimizeDeps.include" warnings. Hoisting
# is the official Nuxt-recommended workaround.
shamefully-hoist=true
