{
  "name": "@2blang/hexedit",
  "version": "0.0.0",
  "description": "Hex editor component for inspecting compiler artifacts.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "sideEffects": [
    "**/*.vue",
    "**/*.css"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "catalog:"
  },
  "devDependencies": {
    "@2blang/eslint-config": "workspace:*",
    "@2blang/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
